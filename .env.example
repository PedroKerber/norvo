# Supabase — obtenha em supabase.com > projeto > Settings > API
REACT_APP_SUPABASE_URL=sua_url_do_projeto_aqui
REACT_APP_SUPABASE_KEY=seu_anon_key_aqui

# EmailJS — obtenha em emailjs.com > Account > API Keys
REACT_APP_EMAILJS_SERVICE_ID=seu_service_id_aqui
REACT_APP_EMAILJS_TEMPLATE_ID=seu_template_id_aqui
REACT_APP_EMAILJS_PUBLIC_KEY=sua_public_key_aqui

# ── Servidor (somente /api — NUNCA expor no front) ──────────────────────────
# Service role do Supabase (Settings > API). Bypassa RLS; só em funções /api.
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_aqui
# Fase 2 · Etapa 1 (Hotfix): IDs (uuid) dos usuários Master autorizados a usar
# os endpoints /api de administração. Separados por vírgula. Server-side apenas.
NORVO_MASTER_IDS=
